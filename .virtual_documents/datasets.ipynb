


# importing libararies
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.datasets import fetch_california_housing
from sklearn.svm import LinearSVR



X, y = fetch_california_housing(return_X_y=True, as_frame=True)
features = ["MedInc", "AveOccup", "HouseAge", "AveRooms"]


plt.scatter(X['MedInc'], X['AveRooms'], marker='o')
plt.show()


file_path = 'WDC_timeSeries.xlsx'
df = pd.read_excel(file_path)

depth_col = df.columns[0]
df_filtered = df[(df[depth_col] >= 3399) & (df[depth_col] <= 3400)]

y = df_filtered.iloc[:, 0]
x = df_filtered.iloc[:, 1]


# Plot
plt.figure(figsize=(8, 5))
plt.scatter(x, y)
plt.xlabel(df.columns[1])
plt.ylabel(df.columns[0])
plt.title('WAIS Divide Core Time Scale')
plt.grid(True)
plt.gca().invert_xaxis()
plt.gca().invert_yaxis()
plt.tight_layout()
plt.show()


energy = pd.read_csv('energy.csv')


plt.figure(figsize=(8, 5))
plt.scatter(energy['timestamp'], energy['load'])
plt.xlabel('timestamp', fontsize=12)
plt.ylabel('load', fontsize=12)
plt.show()
